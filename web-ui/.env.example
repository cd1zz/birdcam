# BirdCam Web UI Configuration
# Copy this file to .env and update with your actual IP addresses

# Pi Capture Server (where cameras are connected)
# Update this to match your Pi's IP address
VITE_PI_SERVER=http://YOUR_PI_IP:8090

# AI Processing Server APIs
# Leave empty to use relative URLs (recommended for production)
# Only set this for development when running UI separately from the processing server
VITE_PROCESSING_SERVER=

# Example for development:
# VITE_PI_SERVER=http://localhost:8090
# VITE_PROCESSING_SERVER=http://localhost:8091